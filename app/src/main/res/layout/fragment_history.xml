<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Recent Matches -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/accent_coral"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Matches"
                        android:textColor="@color/accent_coral"
                        android:textAppearance="@style/TextAppearance.Notifier.CardTitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearMatches"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        android:textColor="@color/accent_coral"
                        android:fontFamily="sans-serif-medium"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Messages the LLM classified as matching your criteria."
                    android:textAppearance="@style/TextAppearance.Notifier.CardSubtitle"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/textRecentMatches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No matches yet. Waiting for notifications..."
                    android:textAppearance="@style/TextAppearance.Notifier.Mono"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Captured Notifications -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/accent_amber"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Captured Notifications"
                        android:textColor="@color/accent_amber"
                        android:textAppearance="@style/TextAppearance.Notifier.CardTitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearCaptured"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        android:textColor="@color/accent_amber"
                        android:fontFamily="sans-serif-medium"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Every notification the listener received, before any filtering."
                    android:textAppearance="@style/TextAppearance.Notifier.CardSubtitle"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/textCaptured"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nothing captured yet."
                    android:textAppearance="@style/TextAppearance.Notifier.Mono"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
