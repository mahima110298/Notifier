<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WhatsAppNotifier" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Typography: mix Android system font families for visible contrast. -->
    <style name="TextAppearance.Notifier.AppTitle" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Notifier.Subtitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_on_primary_muted</item>
    </style>

    <style name="TextAppearance.Notifier.CardTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.Notifier.CardSubtitle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Notifier.TabLabel" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.Notifier.Mono" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
